    },
    "EventHub.Web": {
      "type": "dotnet-project",
      "path": "../../../src/EventHub.Web/EventHub.Web.csproj",
      "launchUrl": "https://localhost:44308",
      "kubernetesService": null,
      "healthCheckEndpoint": "/",
      "healthUiEndpoint": null,
